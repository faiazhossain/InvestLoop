generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  ADMIN
  MEMBER
}

enum BatchStatus {
  OPEN
  CLOSED
}

enum ContributionSource {
  CASH
  REINVEST
}

model User {
  id            String         @id @default(cuid())
  clerkId       String         @unique
  email         String         @unique
  name          String?
  role          UserRole       @default(MEMBER)
  isActive      Boolean        @default(true)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  contributions Contribution[]
  payouts       Payout[]
  reinvestments Reinvestment[]

  @@map("users")
}

model Batch {
  id            String        @id @default(cuid())
  name          String
  description   String?
  principal     Decimal       @default(0) @db.Decimal(15, 2)
  profit        Decimal       @default(0) @db.Decimal(15, 2)
  status        BatchStatus   @default(OPEN)
  startDate     DateTime
  endDate       DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  contributions Contribution[]
  return        Return?
  payouts       Payout[]
  sourceReinvestments  Reinvestment[] @relation("ReinvestmentSource")
  targetReinvestments  Reinvestment[] @relation("ReinvestmentTarget")

  @@map("batches")
}

model Contribution {
  id           String             @id @default(cuid())
  userId       String
  batchId      String
  amount       Decimal            @db.Decimal(15, 2)
  source       ContributionSource @default(CASH)
  date         DateTime           @default(now())
  notes        String?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  batch        Batch              @relation(fields: [batchId], references: [id], onDelete: Cascade)
  reinvestment Reinvestment?

  @@index([userId])
  @@index([batchId])
  @@map("contributions")
}

model Return {
  id          String   @id @default(cuid())
  batchId     String   @unique
  totalReturn Decimal  @db.Decimal(15, 2)
  profit      Decimal  @db.Decimal(15, 2)
  date        DateTime @default(now())
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  batch       Batch    @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@map("returns")
}

model Payout {
  id              String         @id @default(cuid())
  userId          String
  batchId         String
  principal       Decimal        @db.Decimal(15, 2)
  profit          Decimal        @db.Decimal(15, 2)
  grossPayout     Decimal        @db.Decimal(15, 2)
  reinvested      Decimal        @default(0) @db.Decimal(15, 2)
  cashout         Decimal        @db.Decimal(15, 2)
  date            DateTime       @default(now())
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  user            User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  batch           Batch          @relation(fields: [batchId], references: [id], onDelete: Cascade)
  reinvestments   Reinvestment[]

  @@unique([userId, batchId], name: "payout_user_batch_unique")
  @@index([userId])
  @@index([batchId])
  @@map("payouts")
}

model Reinvestment {
  id                 String   @id @default(cuid())
  userId             String
  sourceBatchId      String
  targetBatchId      String
  sourcePayoutId     String
  targetContributionId String? @unique
  amount             Decimal  @db.Decimal(15, 2)
  date               DateTime @default(now())
  notes              String?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  user               User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  sourceBatch        Batch    @relation("ReinvestmentSource", fields: [sourceBatchId], references: [id])
  targetBatch        Batch    @relation("ReinvestmentTarget", fields: [targetBatchId], references: [id])
  sourcePayout       Payout   @relation(fields: [sourcePayoutId], references: [id], onDelete: Cascade)
  targetContribution Contribution? @relation(fields: [targetContributionId], references: [id])

  @@index([userId])
  @@index([sourceBatchId])
  @@index([targetBatchId])
  @@index([sourcePayoutId])
  @@map("reinvestments")
}
